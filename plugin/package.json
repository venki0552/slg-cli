{
  "name": "slg",
  "displayName": "slg — Semantic Git Intelligence",
  "description": "Turn your git history into a queryable knowledge base for AI agents",
  "version": "0.1.0",
  "publisher": "slg-sh",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "AI"],
  "keywords": ["git", "ai", "mcp", "claude", "semantic-search", "llm"],
  "activationEvents": [
    "workspaceContains:.git",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "slg",
      "properties": {
        "slg.autoRegisterMCP": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register slg MCP with Claude Code, Cursor, and other agents"
        },
        "slg.cleanupAfterDays": {
          "type": "number",
          "default": 7,
          "description": "Delete stale branch indices after N days of inactivity"
        },
        "slg.outputFormat": {
          "type": "string",
          "enum": ["text", "xml", "json"],
          "default": "xml",
          "description": "Default output format for MCP responses"
        },
        "slg.enableReranker": {
          "type": "boolean",
          "default": false,
          "description": "Enable cross-encoder reranking (adds ~50ms latency, improves accuracy)"
        },
        "slg.indexOnActivation": {
          "type": "boolean",
          "default": true,
          "description": "Automatically index the workspace when VS Code opens"
        },
        "slg.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show slg status in the VS Code status bar"
        }
      }
    },
    "commands": [
      {
        "command": "slg.doctor",
        "title": "slg: Run Doctor"
      },
      {
        "command": "slg.status",
        "title": "slg: Show Status"
      },
      {
        "command": "slg.reindex",
        "title": "slg: Reindex Workspace"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20",
    "typescript": "^5"
  },
  "dependencies": {
    "which": "^4"
  }
}
